import { NextResponse } from 'next/server'
import { supabaseAdmin } from '@/lib/supabaseAdmin'

export const runtime = 'nodejs'

type Analysis = {
  summary: string
  key_takeaways: string[]
  tags: string[]
  suggested_next_steps: string[]
}

export async function POST(req: Request) {
  const body = await req.json()
  const fileId = body?.file_id as string
  if (!fileId) return NextResponse.json({ error: 'file_id required' }, { status: 400 })

  await supabaseAdmin.from('project_files').update({ status: 'analyzing' }).eq('id', fileId)

  const { data: fileRow, error: fileFetchError } = await supabaseAdmin
    .from('project_files')
    .select('id, storage_path, mime_type')
    .eq('id', fileId)
    .single()

  if (fileFetchError) return NextResponse.json({ error: fileFetchError.message }, { status: 400 })

  const { data: blob, error: downloadError } = await supabaseAdmin.storage
    .from('project-files')
    .download(fileRow.storage_path)

  if (downloadError || !blob) {
    await supabaseAdmin.from('project_files').update({ status: 'failed' }).eq('id', fileId)
    return NextResponse.json({ error: downloadError?.message ?? 'download failed' }, { status: 400 })
  }

  const promptShape = `
Output ONLY valid JSON:

{
  "summary": "...",
  "key_takeaways": ["...","..."],
  "tags": ["...","..."],
  "suggested_next_steps": ["...","..."]
}
`

  const messages: any[] = [{ role: 'system', content: 'You output JSON only.' }]

  let needsTextExtraction = false

  if (fileRow.mime_type?.startsWith('image/')) {
    const buffer = Buffer.from(await blob.arrayBuffer())
    const base64 = buffer.toString('base64')
    const dataUrl = `data:${fileRow.mime_type};base64,${base64}`

    const prompt = `
${promptShape}

You are a creativity coach critiquing AI-generated visual art (Midjourney / DALL·E). Be specific and helpful.
`

    messages.push({
      role: 'user',
      content: [
        { type: 'text', content: prompt },
        { type: 'image_url', image_url: dataUrl },
      ],
    })
  } else if (fileRow.mime_type?.includes('pdf') || fileRow.mime_type?.includes('word')) {
    await supabaseAdmin.from('project_files').update({ status: 'failed' }).eq('id', fileId)
    return NextResponse.json({ error: 'DOCX/PDF analysis not added yet.' }, { status: 400 })
  } else {
    needsTextExtraction = true
  }

  if (needsTextExtraction) {
    const text = await blob.text()
    if (!text.trim()) {
      await supabaseAdmin.from('project_files').update({ status: 'failed' }).eq('id', fileId)
      return NextResponse.json({ error: 'Empty text file.' }, { status: 400 })
    }

    const prompt = `
${promptShape}

Input:
${text}
`

    messages.push({ role: 'user', content: prompt })
  }

  const response = await fetch('https://api.openai.com/v1/chat/completions', {
    method: 'POST',
    headers: {
      Authorization: `Bearer ${process.env.OPENAI_API_KEY}`,
      'Content-Type': 'application/json',
    },
    body: JSON.stringify({ model: 'gpt-4o-mini', messages }),
  })

  if (!response.ok) {
    await supabaseAdmin.from('project_files').update({ status: 'failed' }).eq('id', fileId)
    return NextResponse.json({ error: `OpenAI error ${response.status}` }, { status: 400 })
  }

  const json = await response.json()
  const raw = json?.choices?.[0]?.message?.content ?? ''

  let analysis: Analysis
  try {
    analysis = JSON.parse(raw)
  } catch {
    await supabaseAdmin.from('project_files').update({ status: 'failed' }).eq('id', fileId)
    return NextResponse.json({ error: 'Failed to parse JSON output' }, { status: 400 })
  }

  const { error: insertError } = await supabaseAdmin.from('file_analysis').insert([
    {
      file_id: fileId,
      summary: analysis.summary,
      key_takeaways: analysis.key_takeaways,
      tags: analysis.tags,
      suggested_next_steps: analysis.suggested_next_steps,
    },
  ])

  await supabaseAdmin.from('project_files').update({ status: insertError ? 'failed' : 'ready' }).eq('id', fileId)

  if (insertError) return NextResponse.json({ error: insertError.message }, { status: 400 })
  return NextResponse.json({ analysis })
}
